From 24df2310a9d3362931997c7074123e8d8cec3eff Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Thu, 26 Mar 2026 04:09:38 -0700
Subject: [PATCH] fix missing eglext angle include on linux for chromium

---
 src/3rdparty/chromium/ui/gl/gl_bindings.h | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/3rdparty/chromium/ui/gl/gl_bindings.h b/src/3rdparty/chromium/ui/gl/gl_bindings.h
index 178ee7529b..98b396079f 100644
--- a/src/3rdparty/chromium/ui/gl/gl_bindings.h
+++ b/src/3rdparty/chromium/ui/gl/gl_bindings.h
@@ -33,7 +33,16 @@
 
 // eglext headers reference EGL eums added in the core EGL headers
 #include <EGL/eglext.h>
-#include <EGL/eglext_angle.h>
+//#include <EGL/eglext_angle.h>
+// Use the bundled ANGLE header instead of the system sysroot version.
+// Mesa's eglext_angle.h (confirmed absent in 25.1.5 and 26.0.3) does not
+// contain EGL_ANGLE_global_fence_sync / EGL_SYNC_GLOBAL_FENCE_ANGLE (0x34DE),
+// which was added to ANGLE upstream but never synced into any Mesa release.
+// Using angle brackets (<>) would let the sysroot version load first, setting
+// the file guard INCLUDE_EGL_EGLEXT_ANGLE_ and silently skipping the bundled
+// header for all subsequent includes — including in gl_fence_egl.cc.
+#include "third_party/angle/include/EGL/eglext_angle.h"
+
 #include <stdint.h>
 
 #include "base/logging.h"
